{
  "entities": {
    "Profile": {
      "title": "Party Profile",
      "description": "Represents a first-party (company/individual) or second-party entity profile for agreement generation.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique profile identifier" },
        "userId": { "type": "string", "description": "Owner user ID" },
        "partyType": { "type": "string", "enum": ["first_party_company", "first_party_individual", "second_party"], "description": "Type of party" },
        "name": { "type": "string", "description": "Name of the individual or company" },
        "authorizedSignatory": { "type": "string", "description": "Authorized signatory name (for companies)" },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "phone": { "type": "string", "description": "Phone number" },
        "address": { "type": "string", "description": "Physical registered address" },
        "jurisdiction": { "type": "string", "description": "Legal jurisdiction" },
        "regNumber": { "type": "string", "description": "Company registration/incorporation number if applicable" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when last updated" }
      },
      "required": ["id", "userId", "partyType", "name", "createdAt", "updatedAt"]
    },
    "GeneratedDocument": {
      "title": "Generated Document",
      "description": "Represents a document compiled by the AI with parameters, content, and sharing drafts.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique document identifier" },
        "userId": { "type": "string", "description": "Owner user ID" },
        "type": { "type": "string", "description": "The category/type of document, eg NDA" },
        "title": { "type": "string", "description": "Title or display name for the document" },
        "params": { "type": "object", "description": "Parameters used to generate the document" },
        "content": { "type": "string", "description": "The Markdown-formatted final generated document content" },
        "emailDraft": { "type": "string", "description": "Email draft generated from the document" },
        "whatsappSummary": { "type": "string", "description": "WhatsApp summary generated from the document" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the document was generated" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the document was updated" }
      },
      "required": ["id", "userId", "type", "title", "params", "content", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/profiles/{profileId}": {
      "schema": "Profile",
      "description": "Collection of saved first-party and second-party profiles."
    },
    "/documents/{documentId}": {
      "schema": "GeneratedDocument",
      "description": "Collection of generated legal/business documents."
    }
  }
}
